{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "description": "MCP server exposing NiceOneCode's JSON-to-C# class converter as an AI-callable tool. Requires a NiceOneCode account.",
  "name": "io.github.mr-rahulmaurya/NOC.McpServer",
  "version": "1.0.1",
  "packages": [
    {
      "registryType": "nuget",
      "registryBaseUrl": "https://api.nuget.org",
      "identifier": "NOC.McpServer",
      "version": "1.0.1",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [],
      "environmentVariables": [
        {
          "name": "NOC_USERID",
          "description": "Your NiceOneCode account userid",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "NOC_PASSWORD",
          "description": "Your NiceOneCode account password",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/nice-one-code/NOC.McpServer",
    "source": "github"
  }
}